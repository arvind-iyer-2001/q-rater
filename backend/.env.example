# =============================================================================
# Q-Rater Backend Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Ollama (required) ---
# Run locally: ollama serve  (default port 11434)
# Pull the model first: ollama pull gemma4
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# --- MongoDB Atlas (required) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=q_rater
MONGODB_COLLECTION_CONTENT=content
MONGODB_COLLECTION_USERS=users
MONGODB_VECTOR_INDEX_NAME=content_vector_index

# --- Voyage AI embeddings (required) ---
VOYAGE_API_KEY=pa-...
EMBEDDING_MODEL=voyage-large-2-instruct
EMBEDDING_DIMENSION=1024

# --- Redis / ARQ task queue (optional, falls back to in-process) ---
REDIS_URL=redis://localhost:6379

# --- Whisper transcription ---
WHISPER_MODEL_SIZE=base        # tiny | base | small | medium | large
WHISPER_DEVICE=cpu             # cpu | cuda

# --- Instagram (optional, for private accounts) ---
INSTAGRAM_SESSION_ID=
INSTAGRAM_CSRF_TOKEN=

# --- Media storage ---
MEDIA_TEMP_DIR=/tmp/q_rater_media
MAX_VIDEO_DURATION_SECONDS=600

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
